{
  // Deno for supabase edge functions
  "deno.enablePaths": ["supabase/functions"],
  "deno.lint": true,
  "deno.unstable": [
    "bare-node-builtins",
    "byonm",
    "sloppy-imports",
    "unsafe-proto",
    "webgpu",
    "broadcast-channel",
    "worker-options",
    "cron",
    "kv",
    "ffi",
    "fs",
    "http",
    "net"
  ],

  // Mark auto generated files as readonly
  "files.readonlyInclude": {
    "**/routeTree.gen.ts": true,
    "supabase/types/database.gen.d.ts": true
  },
  "files.watcherExclude": {
    "**/routeTree.gen.ts": true,
    "supabase/types/database.gen.d.ts": true
  },
  "search.exclude": {
    "**/routeTree.gen.ts": true,
    "supabase/types/database.gen.d.ts": true
  },

  // Tailwind
  "files.associations": {
    "*.css": "tailwindcss"
  }
}
